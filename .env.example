PORT=3000
NODE_ENV=development

# Optional: when set, all /api/* routes require Authorization: Bearer <key> or X-API-Key: <key> (except /health).
API_KEY=

# When deploying behind HTTPS (e.g. Vercel), set to true so non-HTTPS requests are rejected unless X-Forwarded-Proto is https.
ENFORCE_HTTPS=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

MONGODB_URI=
MONGODB_DB=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

INGESTION_CRON=*/30 * * * *
