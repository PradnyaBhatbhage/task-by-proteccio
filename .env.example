PORT=3000
NODE_ENV=development

# Optional: when set (and JWT_SECRET unset), all /api/* routes require Authorization: Bearer <key> or X-API-Key: <key>.
API_KEY=

# RBAC: set JWT_SECRET (min 16 chars) to enable JWT login + role-based route permissions.
JWT_SECRET=
JWT_EXPIRES_IN=8h
JWT_ISSUER=proteccio-governance
# Role for machine clients using API_KEY when RBAC is enabled (default: security_analyst).
API_KEY_ROLE=security_analyst
# Seed demo users on startup when RBAC is on (must be false in production).
SEED_DEFAULT_USERS=true

# When deploying behind HTTPS (e.g. Vercel), set to true so non-HTTPS requests are rejected unless X-Forwarded-Proto is https.
ENFORCE_HTTPS=false

# Production (NODE_ENV=production): JWT_SECRET or API_KEY is required; SEED_DEFAULT_USERS must be false.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=

MONGODB_URI=
MONGODB_DB=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

INGESTION_CRON=*/30 * * * *

# Alerting & notifications
ALERTS_ENABLED=true
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=alerts@proteccio.local
# Optional: POST alert payloads as JSON (e.g. Slack/email bridge)
ALERT_WEBHOOK_URL=
ALERT_DEDUPE_TTL_HOURS=24
ALERT_REMEDIATION_OVERDUE_DAYS=7
ALERT_QUEUE_POLL_MS=500
ALERT_IN_APP_ENABLED=true

# Performance (large datasets, reporting, dashboard cache)
DASHBOARD_CACHE_TTL_MS=30000
REPORT_QUEUE_POLL_MS=500
# Auto-queue report generation when catalog has at least this many datasets
ASYNC_REPORT_THRESHOLD_DATASETS=100
REPORT_MAX_COMPLIANCE_ROWS=500
REPORT_MAX_REMEDIATION_TICKETS=500
