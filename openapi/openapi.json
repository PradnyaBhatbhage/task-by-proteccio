                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/ingest/mongodb/collection/full": {
      "post": {
        "tags": [
          "Ingestion"
        ],
        "summary": "Full Mongo collection ingest",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "collectionName"
                ],
                "properties": {
                  "collectionName": {
                    "type": "string"
                  },
                  "batchSize": {
                    "type": "integer"
                  },
